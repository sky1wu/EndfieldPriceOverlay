<Window x:Class="EndfieldPriceOverlay.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="校准识别区域" Width="1280" Height="760" MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="#090E0C" Foreground="#EDF3EF"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Background="#111916">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center">
                <TextBlock x:Name="InstructionText" Text="第 1/2 步：框选完整物资名称" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text=" · 按 Esc 随时取消" Foreground="#778B80" Margin="10,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="取消校准" Style="{StaticResource AppDangerButton}"
                    Margin="0,10,14,10" Padding="16,0" Click="Cancel_Click" />
        </Grid>
        <Grid Grid.Row="1" x:Name="ImageHost" Background="#050806">
            <Image x:Name="ScreenshotImage" Stretch="Uniform" IsHitTestVisible="False" />
            <Canvas x:Name="SelectionCanvas" Background="Transparent"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
                <Rectangle x:Name="SavedNameRectangle" Visibility="Collapsed" Stroke="#62D9FF" StrokeThickness="2"
                           Fill="#2262D9FF" IsHitTestVisible="False" />
                <Rectangle x:Name="ActiveRectangle" Visibility="Collapsed" Stroke="#A9E52E" StrokeThickness="3"
                           Fill="#22A9E52E" IsHitTestVisible="False" />
            </Canvas>
        </Grid>
    </Grid>
</Window>
