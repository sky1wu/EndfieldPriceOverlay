<Window x:Class="EndfieldPriceOverlay.ConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认识别结果" Width="680" Height="330" ResizeMode="NoResize"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner"
        Background="#111916" Foreground="#EAF1EC">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1B2721" />
            <Setter Property="Foreground" Value="#EFF5F1" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="CaretBrush" Value="#A9E52E" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="确认识别结果" FontSize="21" FontWeight="SemiBold" />
            <TextBlock x:Name="HintText" Margin="0,5,0,0" Foreground="#D5A836" />
        </StackPanel>
        <TextBox x:Name="NameBox" Grid.Row="1" Margin="0,18,0,14" FontSize="16" />
        <ItemsControl x:Name="PriceFields" Grid.Row="2">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" Columns="7" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{Binding DateText}" Foreground="#7E9187" FontSize="10" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding DayText}" Foreground="#9DAEA5" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,6" />
                        <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Click="Cancel_Click" />
            <Button Content="确认记录" Background="#A9E52E" Foreground="#0B100E" BorderBrush="#A9E52E" Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</Window>
