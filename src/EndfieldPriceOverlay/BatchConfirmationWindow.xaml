<Window x:Class="EndfieldPriceOverlay.BatchConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认批量识别结果" Width="760" Height="700" MinHeight="560"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner"
        Background="#111916" Foreground="#EAF1EC">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1B2721" />
            <Setter Property="Foreground" Value="#EFF5F1" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="#A9E52E" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource AppButton}">
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="RegionChoice" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#AAB9B1" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ChoiceBorder" Padding="16,8"
                                Background="#17211C" BorderBrush="#34433B" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChoiceBorder" Property="Background" Value="#213027" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChoiceBorder" Property="Background" Value="#26351D" />
                                <Setter TargetName="ChoiceBorder" Property="BorderBrush" Value="#A9E52E" />
                                <Setter Property="Foreground" Value="#DDF4AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="确认当天全部价格" FontSize="21" FontWeight="SemiBold" />
                <TextBlock x:Name="HintText" Margin="0,5,0,0" Foreground="#D5A836" />
            </StackPanel>
            <Border Grid.Column="1" Padding="14,8" Background="#17211C" BorderBrush="#34433B" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="游戏日期" Foreground="#71847A" FontSize="9" HorizontalAlignment="Center" />
                    <TextBlock x:Name="GameDateText" Foreground="#DDF4AF" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="地区" Margin="0,0,14,0" VerticalAlignment="Center" Foreground="#879A90" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton x:Name="ValleyIvOption" Content="四号谷地" Tag="四号谷地" GroupName="Region"
                             Style="{StaticResource RegionChoice}" Checked="Region_Checked" />
                <RadioButton x:Name="WulingOption" Content="武陵" Tag="武陵" GroupName="Region"
                             Style="{StaticResource RegionChoice}" Checked="Region_Checked" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Margin="0,0,0,16" Padding="12,9"
                Background="#0D1511" BorderBrush="#29382F" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="购买额度" Foreground="#E2EBE6" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="6,0">
                    <TextBlock Text="当前可买" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                    <TextBox x:Name="CurrentQuotaBox" Margin="0,4,0,0" TextAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="6,0">
                    <TextBlock Text="容量上限" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                    <TextBox x:Name="QuotaLimitBox" Margin="0,4,0,0" TextAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="6,0">
                    <TextBlock Text="每日恢复" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                    <TextBox x:Name="DailyRecoveryBox" Margin="0,4,0,0" TextAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="QuotaReviewText" Grid.Column="4" Foreground="#D5A836" FontSize="10"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="#" Foreground="#65786E" FontSize="10" />
            <TextBlock Grid.Column="1" Text="物资" Foreground="#65786E" FontSize="10" />
            <TextBlock Grid.Column="2" Text="今日价格" Foreground="#65786E" FontSize="10" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="OCR" Foreground="#65786E" FontSize="10" HorizontalAlignment="Center" />
        </Grid>

        <Border Grid.Row="4" Height="1" Background="#2B3831" />

        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto" Margin="0,4,0,12">
            <ItemsControl x:Name="PriceFields">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#27342C" BorderThickness="0,0,0,1" Padding="0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Number}" Foreground="#71847A" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#E6EDE9"
                                           FontSize="13" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Margin="12,0" Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center" FontSize="15" />
                                <TextBlock Grid.Column="3" Text="{Binding ReviewText}" Foreground="#D5A836"
                                           FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SummaryText" Foreground="#71847A" FontSize="11" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="取消" Click="Cancel_Click" />
                <Button Content="确认全部记录" Style="{StaticResource AppAccentButton}" Margin="8,0,0,0"
                        Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
