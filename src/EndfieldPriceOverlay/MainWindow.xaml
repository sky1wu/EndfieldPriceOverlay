<Window x:Class="EndfieldPriceOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EndfieldPriceOverlay"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="终末地 · 弹性需求物资分析仪"
        Icon="Assets/AppIcon.ico"
        Width="980" Height="640" MinWidth="820" MinHeight="540"
        WindowStyle="None" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen" Background="#0B100E">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#A9E52E" />
        <SolidColorBrush x:Key="Panel" Color="#121A16" />
        <SolidColorBrush x:Key="Line" Color="#28332D" />
        <DataTemplate x:Key="RegionHeaderContent">
            <Grid Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="3" Height="12" Margin="0,0,8,0"
                        Background="{StaticResource Accent}" />
                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                           Foreground="#AEBDB5" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{Binding ItemCount, StringFormat={}{0} GOODS}"
                           VerticalAlignment="Center" Foreground="#596D62" FontSize="9" />
            </Grid>
        </DataTemplate>
        <Style x:Key="RegionHeaderToggle" TargetType="ToggleButton">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#101713" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderSurface" Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  VerticalAlignment="Stretch" />
                                <Path x:Name="Chevron" Grid.Column="1"
                                      Width="6" Height="10" Data="M 1,1 L 5,5 L 1,9"
                                      Stroke="#71847A" StrokeThickness="1.6" Stretch="None"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" RenderTransformOrigin="0.5,0.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="ChevronRotation" />
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderSurface" Property="Background" Value="#17211C" />
                                <Setter TargetName="Chevron" Property="Stroke" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="HeaderSurface" Property="Background" Value="#17211C" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChevronRotation"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="90" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChevronRotation"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="0" Duration="0:0:0.13" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RegionExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="#EEF4F0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton Style="{StaticResource RegionHeaderToggle}"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            <ContentPresenter x:Name="ExpandSite" ContentSource="Content" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InfoButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Foreground" Value="#7F9388" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#18231D" />
                                <Setter Property="Foreground" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#18231D" />
                                <Setter Property="Foreground" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#C7D5CD" />
        </Style>
        <Style x:Key="CloseTitleBarButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFE6E2" />
                    <Setter Property="Background" Value="#7A2F2A" />
                    <Setter Property="BorderBrush" Value="#9A433D" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="#121A16" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#EAF1EC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemSurface" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemSurface" Property="Background" Value="#213027" />
                                <Setter Property="Foreground" Value="#F4F8F5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#667A6F" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="14,2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#2B3831" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#34433B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#0E1512" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <Image Width="30" Height="30" Margin="0,0,12,0" Source="Assets/AppIcon.png"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel>
                        <TextBlock Text="弹性需求物资分析仪" Foreground="#F2F7F3" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="ELASTIC GOODS INTELLIGENCE" Foreground="#6E8377" FontSize="9" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,6,0"
                            VerticalAlignment="Center">
                    <Button x:Name="DebugMenuButton" Style="{StaticResource TitleBarButton}"
                            ToolTip="调试工具" Click="DebugMenu_Click">
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom">
                                <MenuItem Header="调试功能" IsEnabled="False" />
                                <Separator Background="#34433B" />
                                <MenuItem Header="校准 OCR 识别区域…" Click="Calibrate_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="3" Height="3" Margin="0,0,3,0"
                                     Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <Ellipse Width="3" Height="3" Margin="0,0,3,0"
                                     Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <Ellipse Width="3" Height="3"
                                     Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}" ToolTip="最小化" Click="Minimize_Click">
                        <Border Width="12" Height="1.5"
                                Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CloseTitleBarButton}" ToolTip="关闭" Click="Close_Click">
                        <Path Width="12" Height="12" Data="M 1,1 L 11,11 M 11,1 L 1,11"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="ItemsPanel" Background="#101713">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="20,18,20,12">
                        <StackPanel>
                            <TextBlock Text="已记录物资" Foreground="#EEF4F0" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="ItemCountText" Text="0 GOODS" Foreground="#708479" FontSize="10" />
                        </StackPanel>
                    </Grid>
                    <Grid x:Name="ItemsListHost" Grid.Row="1" Margin="12,0,12,14"
                          SizeChanged="ItemsListHost_SizeChanged">
                        <ListBox x:Name="ItemsList"
                                 Background="Transparent" BorderThickness="0" Foreground="#EEF4F0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                 ScrollViewer.ScrollChanged="ItemsList_ScrollChanged"
                                 SelectionChanged="ItemsList_SelectionChanged"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="ItemsList_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="ItemsList_PreviewMouseMove"
                                 DragOver="ItemsList_DragOver"
                                 Drop="ItemsList_Drop">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <Expander Tag="{Binding Name}" Header="{Binding}"
                                                                  HeaderTemplate="{StaticResource RegionHeaderContent}"
                                                                  Style="{StaticResource RegionExpander}"
                                                                  Loaded="RegionExpander_Loaded"
                                                                  Expanded="RegionExpander_Expanded"
                                                                  Collapsed="RegionExpander_Collapsed">
                                                            <ItemsPresenter />
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,5" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="ToolTip" Value="拖动调整顺序" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid x:Name="Root" Background="{TemplateBinding Background}">
                                                    <Border x:Name="SelectionBar" Width="3" Margin="0,8,0,8"
                                                             HorizontalAlignment="Left" Background="{StaticResource Accent}"
                                                             Opacity="0" />
                                                    <ContentPresenter x:Name="ItemContent" Margin="12">
                                                        <ContentPresenter.RenderTransform>
                                                            <TranslateTransform x:Name="ItemOffset" />
                                                        </ContentPresenter.RenderTransform>
                                                    </ContentPresenter>
                                                    <Border x:Name="DropMarkerTop" Height="2" VerticalAlignment="Top"
                                                            Background="{StaticResource Accent}" Visibility="Collapsed" />
                                                    <Border x:Name="DropMarkerBottom" Height="2" VerticalAlignment="Bottom"
                                                            Background="{StaticResource Accent}" Visibility="Collapsed" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#1A251F" />
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="SelectionBar"
                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                     To="1" Duration="0:0:0.14" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="SelectionBar"
                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                     To="0" Duration="0:0:0.1" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#17201B" />
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemOffset"
                                                                                     Storyboard.TargetProperty="X"
                                                                                     To="3" Duration="0:0:0.13">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <QuadraticEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemOffset"
                                                                                     Storyboard.TargetProperty="X"
                                                                                     To="0" Duration="0:0:0.1" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="84" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="44" Height="44" Background="#E9E9E9"
                                                BorderBrush="#34433B" BorderThickness="1" ClipToBounds="True">
                                            <Image Source="{Binding IconPath}" Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Detail}" Foreground="#768A7F" FontSize="10" Margin="0,5,0,0" />
                                        </StackPanel>
                                        <local:TrendControl Grid.Column="2" Height="38" Margin="8,3,0,3"
                                                            Values="{Binding Prices}" ShowGrid="False" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border x:Name="StickyRegionHeader" Height="38"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Panel.ZIndex="2" Visibility="Collapsed"
                                Background="#101713">
                            <ToggleButton x:Name="StickyRegionToggle"
                                          Style="{StaticResource RegionHeaderToggle}"
                                          ContentTemplate="{StaticResource RegionHeaderContent}"
                                          Click="StickyRegionToggle_Click" />
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Column="1" Background="{StaticResource Line}" />

                <Grid x:Name="RightContentGrid" Grid.Column="2" Margin="28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="SelectedHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="58" Height="58" Margin="0,0,14,0" Background="#E9E9E9"
                                BorderBrush="#34433B" BorderThickness="1" ClipToBounds="True">
                            <Image Source="{Binding SelectedItem.IconPath, ElementName=ItemsList}" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="SelectedNameText" Text="等待记录" Foreground="#F1F6F2"
                                       FontSize="26" FontWeight="SemiBold" />
                            <TextBlock x:Name="SelectedMetaText" Text="打开游戏物资详情页，然后开始识别"
                                       Foreground="#778B80" FontSize="12" Margin="0,6,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Text="RECENT 7 RECORDS" Foreground="#65786E"
                                       FontSize="10" HorizontalAlignment="Right" />
                            <Button x:Name="EditPricesButton" Style="{StaticResource AppQuietButton}"
                                    Content="管理价格记录" IsEnabled="False"
                                    Margin="0,8,0,0" Padding="12,6" FontSize="11"
                                    Click="EditPrices_Click" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,20,0,12" Background="#0D1411"
                            BorderBrush="#26322B" BorderThickness="1" CornerRadius="3">
                        <local:TrendControl x:Name="MainTrend" Margin="14,10,14,8" StrokeThickness="2.2" ShowLabels="True" />
                    </Border>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="本周价格" Foreground="#DDE7E1" FontSize="14"
                                           FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Style="{StaticResource InfoButton}" Click="PredictionInfo_Click"
                                        ToolTip="查看预测算法与使用边界">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="15" Height="15" Margin="0,0,5,0" CornerRadius="8"
                                                BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                BorderThickness="1">
                                            <TextBlock Text="i" FontSize="10" FontWeight="Bold"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="原理说明" FontSize="10"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock x:Name="PredictionMessageText" Text="记录完整数据后显示预测结果"
                                       Foreground="#D8A934" FontSize="12" Margin="0,6,14,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                            <Border x:Name="RequiredDaysBadge" Visibility="Collapsed" CornerRadius="3"
                                     Background="#1A251F" BorderBrush="#39483F" BorderThickness="1"
                                    Padding="12,7" HorizontalAlignment="Right">
                                <TextBlock x:Name="RequiredDaysText" Text="还需 1 天" Foreground="{StaticResource Accent}"
                                           FontSize="14" FontWeight="SemiBold" />
                            </Border>
                            <Button x:Name="CandidateTrendsButton" Style="{StaticResource AppGhostButton}"
                                    Visibility="Collapsed"
                                    Margin="0,6,0,0" Padding="12,6" HorizontalAlignment="Right"
                                    Foreground="{StaticResource Accent}" FontSize="11"
                                    Content="展开全部走势" Click="CandidateTrends_Click" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3" Margin="0,12,0,20" Background="#0D1411"
                            BorderBrush="#26322B" BorderThickness="1" CornerRadius="3">
                        <Grid>
                            <local:WeekPriceChartControl x:Name="ForecastChart" Margin="14,10,14,8" />
                            <TextBlock x:Name="ForecastEmptyText" Text="暂无本周价格数据"
                                       Foreground="#65786E" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border x:Name="CandidateTrendsPanel" Grid.Row="1" Grid.RowSpan="3"
                            Margin="0,12,0,20" Panel.ZIndex="4" Visibility="Collapsed"
                            Background="#101713" BorderBrush="#405247" BorderThickness="1">
                        <Grid Margin="14,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="CandidateTrendsTitle" Text="全部候选走势"
                                               Foreground="#EFF5F1" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock x:Name="CandidateWeekText" Margin="0,4,0,0"
                                               Foreground="#71847A" FontSize="10"
                                               Text="相同价格序列已合并" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource AppGhostButton}"
                                        Content="收起" Padding="12,6"
                                        VerticalAlignment="Top" Click="CloseCandidateTrends_Click" />
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,12,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="走势" Foreground="#65786E" FontSize="9"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="一" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="二" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="三" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="5" Text="四" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="6" Text="五" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="7" Text="六" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="8" Text="日" Foreground="#65786E" FontSize="9" HorizontalAlignment="Center" />
                            </Grid>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="CandidateTrendRows">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#27342C" BorderThickness="0,0,0,1" Padding="0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="88" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding IndexText}" Foreground="#71847A" FontSize="9"
                                                               VerticalAlignment="Center" />
                                                    <local:TrendControl Grid.Column="1" Height="30" Margin="3,0,9,0"
                                                                        Values="{Binding Trend}" ShowGrid="False" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Prices[0]}" Foreground="#DCE6E0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Prices[1]}" Foreground="#DCE6E0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="4" Text="{Binding Prices[2]}" Foreground="#DCE6E0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="5" Text="{Binding Prices[3]}" Foreground="#DCE6E0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="6" Text="{Binding Prices[4]}" Foreground="#DCE6E0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="7" Text="{Binding Prices[5]}" Foreground="#DCE6E0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="8" Text="{Binding Prices[6]}" Foreground="#DCE6E0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="记录物资价格" Foreground="#DDE7E1" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="详情页录入历史；调度页批量录入今日价格"
                                       Foreground="#687C71" FontSize="10" Margin="0,3,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Style="{StaticResource AppQuietButton}"
                                Width="116" Height="46" Padding="12,0" Margin="0,0,10,0"
                                FontSize="13" FontWeight="SemiBold"
                                Content="购买建议" Click="PurchasePlanner_Click" />
                            <Button x:Name="BatchRecognizeButton" Style="{StaticResource AppAccentButton}"
                                Width="176" Height="46" Padding="14,0" Margin="0,0,10,0"
                                FontSize="13" FontWeight="SemiBold"
                                Content="批量识别今日价格" Click="BatchRecognize_Click" />
                            <Button x:Name="RecognizeButton"
                                Width="140" Height="46" Padding="14,0" Margin="0"
                                FontSize="13" FontWeight="SemiBold"
                                Content="识别当前物资" Click="Recognize_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="StatusBar" Grid.Row="2" Background="#0A0F0D">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot" Width="7" Height="7" Margin="18,0,8,0"
                         Fill="{StaticResource Accent}" />
                <TextBlock x:Name="StatusText" Grid.Column="1" Text="就绪 · 等待识别 Endfield 窗口"
                           Foreground="#72857A" FontSize="10" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="LOCAL DATA · OCR OFFLINE" Foreground="#526158"
                           FontSize="9" VerticalAlignment="Center" Margin="0,0,18,0" />
            </Grid>
        </Grid>
    </Border>
</Window>
