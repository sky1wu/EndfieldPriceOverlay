<Window x:Class="EndfieldPriceOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EndfieldPriceOverlay"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="终末地 · 弹性需求物资分析仪"
        Width="980" Height="640" MinWidth="820" MinHeight="540"
        WindowStyle="None" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen" Background="#0B100E">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#A9E52E" />
        <SolidColorBrush x:Key="Panel" Color="#121A16" />
        <SolidColorBrush x:Key="Line" Color="#28332D" />
        <Style x:Key="ScrollPageButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="#61756A" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Border x:Name="ThumbBody" Width="4" Margin="0,1"
                                    HorizontalAlignment="Center"
                                    Background="{TemplateBinding Background}" CornerRadius="2" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBody" Property="Background" Value="#92C82B" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBody" Property="Background" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ItemListScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Margin" Value="4,2,0,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Border x:Name="Rail" Width="2" HorizontalAlignment="Center"
                                    Background="#24322A" CornerRadius="1" />
                            <Track x:Name="PART_Track" Margin="0,3" Orientation="Vertical"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollPageButton}"
                                                  Command="{x:Static ScrollBar.PageUpCommand}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollPageButton}"
                                                  Command="{x:Static ScrollBar.PageDownCommand}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Rail" Property="Background" Value="#34463C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="RegionHeaderContent">
            <Grid Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="3" Height="12" Margin="0,0,8,0"
                        Background="{StaticResource Accent}" />
                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                           Foreground="#AEBDB5" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{Binding ItemCount, StringFormat={}{0} GOODS}"
                           VerticalAlignment="Center" Foreground="#596D62" FontSize="9" />
            </Grid>
        </DataTemplate>
        <Style x:Key="RegionHeaderToggle" TargetType="ToggleButton">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#101713" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderSurface" Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  VerticalAlignment="Stretch" />
                                <TextBlock x:Name="Chevron" Grid.Column="1" Text="›"
                                           Foreground="#71847A" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderSurface" Property="Background" Value="#17211C" />
                                <Setter TargetName="Chevron" Property="Foreground" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="HeaderSurface" Property="Background" Value="#17211C" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chevron" Property="Text" Value="⌄" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RegionExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="#EEF4F0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton Style="{StaticResource RegionHeaderToggle}"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            <ContentPresenter x:Name="ExpandSite" ContentSource="Content" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EAF1EC" />
            <Setter Property="Background" Value="#1B2721" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#26362D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#0B100E" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="#121A16" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#EAF1EC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemSurface" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemSurface" Property="Background" Value="#213027" />
                                <Setter Property="Foreground" Value="#F4F8F5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#667A6F" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="10,2" />
            <Setter Property="Background" Value="#2B3831" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#34433B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#0E1512" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <Border Width="30" Height="30" Background="{StaticResource Accent}" Margin="0,0,12,0">
                        <TextBlock Text="EP" Foreground="#0B100E" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="弹性需求物资分析仪" Foreground="#F2F7F3" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="ELASTIC GOODS INTELLIGENCE" Foreground="#6E8377" FontSize="9" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="DebugMenuButton" Width="48" Height="58" Padding="0" BorderThickness="0"
                            Background="Transparent" Content="•••" FontSize="12" ToolTip="调试工具"
                            Click="DebugMenu_Click">
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom">
                                <MenuItem Header="调试功能" IsEnabled="False" />
                                <Separator Background="#34433B" />
                                <MenuItem Header="校准 OCR 识别区域…" Click="Calibrate_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Width="48" Height="58" Padding="0" BorderThickness="0" Background="Transparent"
                            Content="—" Click="Minimize_Click" />
                    <Button Width="48" Height="58" Padding="0" BorderThickness="0" Background="Transparent"
                            Content="×" FontSize="20" Click="Close_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Background="#101713">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="20,18,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="已记录物资" Foreground="#EEF4F0" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="ItemCountText" Text="0 GOODS" Foreground="#708479" FontSize="10" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="刷新" Padding="12,6" VerticalAlignment="Center" Click="Refresh_Click" />
                    </Grid>
                    <Grid x:Name="ItemsListHost" Grid.Row="1" Margin="12,0,12,14"
                          SizeChanged="ItemsListHost_SizeChanged">
                        <ListBox x:Name="ItemsList"
                                 Background="Transparent" BorderThickness="0" Foreground="#EEF4F0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                 ScrollViewer.ScrollChanged="ItemsList_ScrollChanged"
                                 SelectionChanged="ItemsList_SelectionChanged">
                            <ListBox.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ItemListScrollBar}" />
                            </ListBox.Resources>
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <Expander Tag="{Binding Name}" Header="{Binding}"
                                                                  HeaderTemplate="{StaticResource RegionHeaderContent}"
                                                                  Style="{StaticResource RegionExpander}"
                                                                  Loaded="RegionExpander_Loaded"
                                                                  Expanded="RegionExpander_Expanded"
                                                                  Collapsed="RegionExpander_Collapsed">
                                                            <ItemsPresenter />
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,5" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid x:Name="Root" Background="{TemplateBinding Background}">
                                                    <Border x:Name="SelectionBar" Width="3" Margin="0,8,0,8"
                                                            HorizontalAlignment="Left" Background="{StaticResource Accent}"
                                                            Visibility="Collapsed" />
                                                    <ContentPresenter Margin="12" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#1A251F" />
                                                        <Setter TargetName="SelectionBar" Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#17201B" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="84" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="44" Height="44" Background="#E9E9E9"
                                                BorderBrush="#34433B" BorderThickness="1" ClipToBounds="True">
                                            <Image Source="{Binding IconPath}" Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Detail}" Foreground="#768A7F" FontSize="10" Margin="0,5,0,0" />
                                        </StackPanel>
                                        <local:TrendControl Grid.Column="2" Height="38" Margin="8,3,0,3"
                                                            Values="{Binding Prices}" ShowGrid="False" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border x:Name="StickyRegionHeader" Height="38"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Panel.ZIndex="2" Visibility="Collapsed"
                                Background="#101713">
                            <ToggleButton x:Name="StickyRegionToggle"
                                          Style="{StaticResource RegionHeaderToggle}"
                                          ContentTemplate="{StaticResource RegionHeaderContent}"
                                          Click="StickyRegionToggle_Click" />
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Column="1" Background="{StaticResource Line}" />

                <Grid Grid.Column="2" Margin="28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="205" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="58" Height="58" Margin="0,0,14,0" Background="#E9E9E9"
                                BorderBrush="#34433B" BorderThickness="1" ClipToBounds="True">
                            <Image Source="{Binding SelectedItem.IconPath, ElementName=ItemsList}" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="SelectedNameText" Text="等待记录" Foreground="#F1F6F2"
                                       FontSize="26" FontWeight="SemiBold" />
                            <TextBlock x:Name="SelectedMetaText" Text="打开游戏物资详情页，然后开始识别"
                                       Foreground="#778B80" FontSize="12" Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="RECENT 7 RECORDS" Foreground="#65786E"
                                   FontSize="10" VerticalAlignment="Bottom" />
                    </Grid>

                    <Border Grid.Row="1" Margin="0,20,0,12" Background="#0D1411" BorderBrush="#26322B" BorderThickness="1">
                        <local:TrendControl x:Name="MainTrend" Margin="14,10,14,8" StrokeThickness="2.2" ShowLabels="True" />
                    </Border>

                    <Grid Grid.Row="2" Margin="0,8,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="未来价格" Foreground="#DDE7E1" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock x:Name="PredictionMessageText" Text="记录完整数据后显示预测结果"
                                           Foreground="#D8A934" FontSize="12" Margin="0,6,14,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border x:Name="RequiredDaysBadge" Grid.Column="1" Visibility="Collapsed"
                                    Background="#1A251F" BorderBrush="#39483F" BorderThickness="1"
                                    Padding="12,7" VerticalAlignment="Top">
                                <TextBlock x:Name="RequiredDaysText" Text="还需 1 天" Foreground="{StaticResource Accent}"
                                           FontSize="14" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <ItemsControl x:Name="ForecastList" Grid.Row="1" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#27342C" BorderThickness="0,0,0,1" Padding="4,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DateText}" Foreground="#819489" />
                                            <TextBlock Grid.Column="1" Text="{Binding DayText}" Foreground="#A9B7AF" />
                                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="{StaticResource Accent}"
                                                       FontSize="18" FontWeight="SemiBold" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                            <TextBlock Text="记录物资价格" Foreground="#DDE7E1" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="详情页录入历史；调度页批量录入今日价格" Foreground="#687C71" FontSize="10" Margin="0,3,0,0" />
                        </StackPanel>
                        <Button x:Name="BatchRecognizeButton" Style="{StaticResource AccentButton}"
                                Grid.Column="1" Width="170" Height="58" Padding="16,0" Margin="0,0,10,0"
                                FontSize="14" FontWeight="SemiBold"
                                Content="批量识别今日价格" Click="BatchRecognize_Click" />
                        <Button x:Name="RecognizeButton"
                                Grid.Column="2" Width="140" Height="58" Padding="16,0"
                                FontSize="14" FontWeight="SemiBold"
                                Content="识别当前物资" Click="Recognize_Click" />
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Background="#0A0F0D">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Width="7" Height="7" Margin="18,0,8,0" Fill="{StaticResource Accent}" />
                <TextBlock x:Name="StatusText" Grid.Column="1" Text="就绪 · 等待识别 Endfield 窗口"
                           Foreground="#72857A" FontSize="10" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="LOCAL DATA · OCR OFFLINE" Foreground="#526158"
                           FontSize="9" VerticalAlignment="Center" Margin="0,0,18,0" />
            </Grid>
        </Grid>
    </Border>
</Window>
