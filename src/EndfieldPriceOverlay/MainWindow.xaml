<Window x:Class="EndfieldPriceOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EndfieldPriceOverlay"
        Title="终末地 · 弹性物资分析仪"
        Width="980" Height="640" MinWidth="820" MinHeight="540"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen" Background="#0B100E">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#A9E52E" />
        <SolidColorBrush x:Key="Panel" Color="#121A16" />
        <SolidColorBrush x:Key="Line" Color="#28332D" />
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EAF1EC" />
            <Setter Property="Background" Value="#1B2721" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#26362D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#0B100E" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="#34433B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#0E1512" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <Border Width="30" Height="30" Background="{StaticResource Accent}" Margin="0,0,12,0">
                        <TextBlock Text="EP" Foreground="#0B100E" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="弹性物资分析仪" Foreground="#F2F7F3" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="ENDFIELD MARKET INTELLIGENCE" Foreground="#6E8377" FontSize="9" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Width="48" Height="58" Padding="0" BorderThickness="0" Background="Transparent"
                            Content="—" Click="Minimize_Click" />
                    <Button Width="48" Height="58" Padding="0" BorderThickness="0" Background="Transparent"
                            Content="×" FontSize="20" Click="Close_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Background="#101713">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="20,18,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="已记录商品" Foreground="#EEF4F0" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="ItemCountText" Text="0 ITEMS" Foreground="#708479" FontSize="10" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="刷新" Padding="12,6" VerticalAlignment="Center" Click="Refresh_Click" />
                    </Grid>
                    <ListBox x:Name="ItemsList" Grid.Row="1" Margin="12,0,12,14"
                             Background="Transparent" BorderThickness="0" Foreground="#EEF4F0"
                             SelectionChanged="ItemsList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,5" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Root" Padding="12" Background="{TemplateBinding Background}"
                                                    BorderBrush="#253129" BorderThickness="0,0,0,1">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#1A251F" />
                                                    <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#17201B" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Detail}" Foreground="#768A7F" FontSize="10" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <local:TrendControl Grid.Column="1" Height="38" Margin="10,0,0,0"
                                                        Values="{Binding Prices}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Border Grid.Column="1" Background="{StaticResource Line}" />

                <Grid Grid.Column="2" Margin="28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="SelectedNameText" Text="等待记录" Foreground="#F1F6F2"
                                       FontSize="26" FontWeight="SemiBold" />
                            <TextBlock x:Name="SelectedMetaText" Text="打开游戏商品详情页，然后开始识别"
                                       Foreground="#778B80" FontSize="12" Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="PRICE TREND / 30D" Foreground="#65786E"
                                   FontSize="10" VerticalAlignment="Bottom" />
                    </Grid>

                    <Border Grid.Row="1" Margin="0,20,0,12" Background="#0D1411" BorderBrush="#26322B" BorderThickness="1">
                        <local:TrendControl x:Name="MainTrend" Margin="16" StrokeThickness="2.2" />
                    </Border>

                    <Grid Grid.Row="2" Margin="0,8,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="未来价格" Foreground="#DDE7E1" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock x:Name="PredictionMessageText" Text="记录完整数据后显示预测结果"
                                       Foreground="#D8A934" FontSize="12" Margin="0,6,0,0" />
                        </StackPanel>
                        <ItemsControl x:Name="ForecastList" Grid.Row="1" Margin="0,18,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#27342C" BorderThickness="0,0,0,1" Padding="4,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DateText}" Foreground="#819489" />
                                            <TextBlock Grid.Column="1" Text="{Binding DayText}" Foreground="#A9B7AF" />
                                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="{StaticResource Accent}"
                                                       FontSize="18" FontWeight="SemiBold" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="校准区域" Margin="0,0,10,0" Click="Calibrate_Click" />
                        <Button x:Name="RecognizeButton" Style="{StaticResource AccentButton}"
                                Content="识别当前商品" Click="Recognize_Click" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Background="#0A0F0D">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Width="7" Height="7" Margin="18,0,8,0" Fill="{StaticResource Accent}" />
                <TextBlock x:Name="StatusText" Grid.Column="1" Text="就绪 · 等待识别 Endfield 窗口"
                           Foreground="#72857A" FontSize="10" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="LOCAL DATA · OCR OFFLINE" Foreground="#526158"
                           FontSize="9" VerticalAlignment="Center" Margin="0,0,18,0" />
            </Grid>
        </Grid>
    </Border>
</Window>
