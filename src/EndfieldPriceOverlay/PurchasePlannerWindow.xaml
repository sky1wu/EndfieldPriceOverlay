<Window x:Class="EndfieldPriceOverlay.PurchasePlannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="购买建议" Width="760" Height="680" MinHeight="540"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner"
        Background="#111916" Foreground="#EAF1EC">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1B2721" />
            <Setter Property="Foreground" Value="#EFF5F1" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="#A9E52E" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="本周购买建议" FontSize="21" FontWeight="SemiBold" />
            <TextBlock Margin="0,5,0,0" Foreground="#9DAEA5" FontSize="12"
                       Text="先最大化购买件数，再按预测最低价选择日期和物资。" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="地区" Foreground="#65786E" FontSize="10" />
            <TextBlock Grid.Column="1" Text="当前可买" Foreground="#65786E" FontSize="10" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="上限" Foreground="#65786E" FontSize="10" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="每日恢复" Foreground="#65786E" FontSize="10" HorizontalAlignment="Center" />
        </Grid>

        <ItemsControl x:Name="RegionFields" Grid.Row="2">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#27342C" BorderThickness="0,0,0,1" Padding="0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Region}" Foreground="#E6EDE9"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Margin="0,0,12,0"
                                     Text="{Binding Current, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="2" Margin="0,0,12,0"
                                     Text="{Binding Limit, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="3"
                                     Text="{Binding DailyRecovery, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,18,0,16">
            <ItemsControl x:Name="AdviceGroups">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#2B3831" BorderThickness="1" Background="#0D1411"
                                Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Region}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding TotalText}" Foreground="#DDF4AF"
                                               FontSize="15" FontWeight="SemiBold" />
                                </Grid>
                                <TextBlock Text="{Binding Message}" Margin="0,6,0,12"
                                           Foreground="#9DAEA5" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding EmptyText}" Foreground="#65786E" FontSize="12" />
                                <ItemsControl ItemsSource="{Binding Lines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#27342C" BorderThickness="0,1,0,0" Padding="0,9">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="92" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="86" />
                                                        <ColumnDefinition Width="96" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DateText}" Foreground="#DCE6E0"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding QuantityText}"
                                                               Foreground="#A9E52E" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding ItemName}"
                                                               Foreground="#E6EDE9" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="3" Text="{Binding PriceText}"
                                                               Foreground="#879A90" HorizontalAlignment="Right"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="4" Text="{Binding AvailableText}"
                                                               Foreground="#65786E" HorizontalAlignment="Right"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SummaryText" Foreground="#71847A" FontSize="11" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="关闭" Click="Close_Click" />
                <Button Content="生成建议" Background="#A9E52E" Foreground="#0B100E"
                        BorderBrush="#A9E52E" Click="Generate_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
