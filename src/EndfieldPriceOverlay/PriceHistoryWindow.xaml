<Window x:Class="EndfieldPriceOverlay.PriceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理价格记录" Width="1160" Height="650" MinWidth="1040" MinHeight="520"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner"
        Background="#111916" Foreground="#EAF1EC">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1B2721" />
            <Setter Property="Foreground" Value="#EFF5F1" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="#A9E52E" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="管理价格记录" FontSize="21" FontWeight="SemiBold" />
                <TextBlock x:Name="ItemNameText" Margin="0,5,0,0" Foreground="#9DAEA5" FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="新增一周数据" Foreground="#DCE6E0"
                        BorderBrush="#405247" Background="#18231D" Click="AddWeek_Click" />
                <Button Content="全部标记删除" Foreground="#E9A19A"
                        BorderBrush="#68403C" Background="#241917" Click="DeleteAll_Click" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" Margin="0,14,0,14" Foreground="#71847A" FontSize="11"
                   Text="可直接在空白日期录入价格；点击保存后趋势和预测会立即更新。" />

        <Grid Grid.Row="2" Height="34" Margin="0,0,18,4" Background="#0D1411">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="自然周" Margin="12,0,0,0" Foreground="#65786E" FontSize="10" VerticalAlignment="Center" />
            <UniformGrid Grid.Column="1" Rows="1" Columns="7">
                <TextBlock Text="周一" Foreground="#879A90" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock Text="周二" Foreground="#879A90" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock Text="周三" Foreground="#879A90" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock Text="周四" Foreground="#879A90" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock Text="周五" Foreground="#879A90" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock Text="周六" Foreground="#879A90" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock Text="周日" Foreground="#879A90" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </UniformGrid>
        </Grid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="PriceWeeks">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="96">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#151F1A" BorderBrush="#27342C" BorderThickness="0,0,1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="3" Height="18" Background="#A9E52E" />
                                    <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DateRangeText}" Foreground="#DCE6E0"
                                                   FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RecordCountText}" Margin="0,5,0,0"
                                                   Foreground="#71847A" FontSize="10" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" Columns="7" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="CellBorder" BorderBrush="#27342C"
                                                BorderThickness="0,0,1,1" Padding="7,7,7,6">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DateText}" Foreground="#71847A"
                                                               FontSize="9" HorizontalAlignment="Center" />
                                                    <TextBox x:Name="PriceBox" Margin="0,5,0,0" Padding="5,4"
                                                             Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                                                             TextAlignment="Center" FontSize="14"
                                                             ToolTip="输入 300～5500 的整数" />
                                                    <Button x:Name="DeleteButton" Content="{Binding ActionText}" Margin="0,4,0,0" Padding="5,2"
                                                            Foreground="#E9A19A" Background="Transparent"
                                                            BorderThickness="0" FontSize="9" Click="DeleteRow_Click" />
                                                    <TextBlock x:Name="MissingText" Text="未记录 · 可输入" Visibility="Collapsed"
                                                               Margin="0,5,0,0" Foreground="#65786E" FontSize="9"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                <Setter TargetName="CellBorder" Property="Opacity" Value="0.55" />
                                                <Setter TargetName="PriceBox" Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasOriginalRecord}" Value="False">
                                                <Setter TargetName="DeleteButton" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="MissingText" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="CellBorder" Property="Background" Value="#0D1411" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SummaryText" Foreground="#71847A" FontSize="11" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="取消" Click="Cancel_Click" />
                <Button Content="保存修改" Background="#A9E52E" Foreground="#0B100E"
                        BorderBrush="#A9E52E" Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
