<Window x:Class="EndfieldPriceOverlay.PriceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理价格记录" Width="1160" Height="650" MinWidth="1040" MinHeight="520"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner"
        Background="#111916" Foreground="#EAF1EC">
    <Window.Resources>
        <Style x:Key="PriceEditor" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F1F6F3" />
            <Setter Property="BorderBrush" Value="#31443A" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="CaretBrush" Value="#A9E52E" />
            <Setter Property="SelectionBrush" Value="#648A26" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="EditorSurface" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorSurface" Property="BorderBrush" Value="#51685B" />
                                <Setter TargetName="EditorSurface" Property="Background" Value="#121D17" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorSurface" Property="BorderBrush" Value="#A9E52E" />
                                <Setter TargetName="EditorSurface" Property="Background" Value="#15221B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorSurface" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource PriceEditor}" />
        <Style TargetType="Button" BasedOn="{StaticResource AppButton}">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="CellActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Foreground" Value="#B2847F" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Opacity" Value="0.42" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFB1A9" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ColumnLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#71857A" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="28,22,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="管理价格记录" FontSize="21" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Border Width="3" Height="14" Margin="0,0,8,0" Background="#A9E52E" />
                    <TextBlock x:Name="ItemNameText" Foreground="#A7B8AF" FontSize="12" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="新增一周" Style="{StaticResource AppQuietButton}" Click="AddWeek_Click" />
                <Button Content="全部标记删除" Style="{StaticResource AppDangerButton}"
                        Margin="8,0,0,0" Click="DeleteAll_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Foreground="#74877C" FontSize="11"
                       Text="空白日期可直接录入；价格范围为 300～5500。" />
            <TextBlock Grid.Column="1" Foreground="#52645A" FontSize="10"
                       Text="保存后立即更新趋势与预测" />
        </Grid>

        <Border Grid.Row="2" Height="34" Margin="0,0,12,0"
                Background="#0B120F" BorderBrush="#25332C" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="172" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="自然周 / 已记录" Margin="16,0,0,0" Foreground="#71857A"
                           FontSize="10" VerticalAlignment="Center" />
                <UniformGrid Grid.Column="1" Rows="1" Columns="7">
                    <TextBlock Text="周一" Style="{StaticResource ColumnLabel}" />
                    <TextBlock Text="周二" Style="{StaticResource ColumnLabel}" />
                    <TextBlock Text="周三" Style="{StaticResource ColumnLabel}" />
                    <TextBlock Text="周四" Style="{StaticResource ColumnLabel}" />
                    <TextBlock Text="周五" Style="{StaticResource ColumnLabel}" />
                    <TextBlock Text="周六" Style="{StaticResource ColumnLabel}" />
                    <TextBlock Text="周日" Style="{StaticResource ColumnLabel}" />
                </UniformGrid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
            <ItemsControl x:Name="PriceWeeks" AlternationCount="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="WeekRow" MinHeight="92" Padding="0,9"
                                BorderBrush="#24332B" BorderThickness="0,0,0,1"
                                Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="WeekOffset" Y="7" />
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="WeekOffset"
                                                             Storyboard.TargetProperty="Y"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="172" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Margin="0,0,10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="3" Height="28" Background="#A9E52E" />
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DateRangeText}" Foreground="#E3ECE7"
                                                   FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RecordCountText}" Margin="0,7,0,0"
                                                   Foreground="#71857A" FontSize="9" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="CellBorder" Margin="3,0" Padding="8,6"
                                                    Background="Transparent">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="20" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding DateText}" Foreground="#71857A"
                                                               FontSize="9" HorizontalAlignment="Center" />
                                                    <TextBox x:Name="PriceBox" Grid.Row="1" Margin="0,5,0,0"
                                                             Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="输入 300～5500 的整数" />
                                                    <Grid Grid.Row="2" Margin="0,3,0,0">
                                                        <Button x:Name="DeleteButton" Style="{StaticResource CellActionButton}"
                                                                Content="{Binding ActionText}" HorizontalAlignment="Center"
                                                                Click="DeleteRow_Click" />
                                                        <TextBlock x:Name="MissingText" Text="待录入" Visibility="Collapsed"
                                                                   Foreground="#52675C" FontSize="9"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <Trigger SourceName="CellBorder" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CellBorder" Property="Background" Value="#121D17" />
                                                    <Setter TargetName="DeleteButton" Property="Opacity" Value="1" />
                                                </Trigger>
                                                <Trigger SourceName="PriceBox" Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter TargetName="CellBorder" Property="Background" Value="#142019" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding HasOriginalRecord}" Value="False">
                                                    <Setter TargetName="DeleteButton" Property="Visibility" Value="Collapsed" />
                                                    <Setter TargetName="MissingText" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="CellBorder" Property="Background" Value="Transparent" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter TargetName="CellBorder" Property="Opacity" Value="0.5" />
                                                    <Setter TargetName="CellBorder" Property="Background" Value="#1B1514" />
                                                    <Setter TargetName="PriceBox" Property="IsEnabled" Value="False" />
                                                    <Setter TargetName="DeleteButton" Property="Opacity" Value="1" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter TargetName="WeekRow" Property="Background" Value="#0E1612" />
                            </Trigger>
                            <Trigger SourceName="WeekRow" Property="IsMouseOver" Value="True">
                                <Setter TargetName="WeekRow" Property="Background" Value="#121C17" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="4" Margin="0,14,0,0" Padding="0,14,0,0"
                BorderBrush="#29372F" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SummaryText" Foreground="#7F9388" FontSize="11" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消" Click="Cancel_Click" />
                    <Button Content="保存修改" Style="{StaticResource AppAccentButton}" Margin="8,0,0,0"
                            Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
