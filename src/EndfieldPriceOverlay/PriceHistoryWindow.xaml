<Window x:Class="EndfieldPriceOverlay.PriceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理价格记录" Width="620" Height="650" MinHeight="500"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner"
        Background="#111916" Foreground="#EAF1EC">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1B2721" />
            <Setter Property="Foreground" Value="#EFF5F1" />
            <Setter Property="BorderBrush" Value="#34433B" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="#A9E52E" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="管理价格记录" FontSize="21" FontWeight="SemiBold" />
                <TextBlock x:Name="ItemNameText" Margin="0,5,0,0" Foreground="#9DAEA5" FontSize="13" />
            </StackPanel>
            <Button Grid.Column="1" Content="全部标记删除" Foreground="#E9A19A"
                    BorderBrush="#68403C" Background="#241917" Click="DeleteAll_Click" />
        </Grid>

        <TextBlock Grid.Row="1" Margin="0,14,0,14" Foreground="#71847A" FontSize="11"
                   Text="可修改单日价格或标记删除；点击保存后趋势和预测会立即更新。" />

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="日期" Foreground="#65786E" FontSize="10" />
            <TextBlock Grid.Column="1" Text="星期" Foreground="#65786E" FontSize="10" />
            <TextBlock Grid.Column="2" Text="价格" Foreground="#65786E" FontSize="10" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="操作" Foreground="#65786E" FontSize="10" HorizontalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PriceFields">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="RowBorder" BorderBrush="#27342C" BorderThickness="0,0,0,1" Padding="0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DateText}" Foreground="#DCE6E0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding WeekdayText}" Foreground="#879A90" VerticalAlignment="Center" />
                                <TextBox x:Name="PriceBox" Grid.Column="2" Margin="12,0"
                                         Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center" FontSize="15" />
                                <Button Grid.Column="3" Content="{Binding ActionText}" Padding="12,6"
                                        Foreground="#E9A19A" Click="DeleteRow_Click" />
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                <Setter TargetName="RowBorder" Property="Opacity" Value="0.45" />
                                <Setter TargetName="PriceBox" Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SummaryText" Foreground="#71847A" FontSize="11" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="取消" Click="Cancel_Click" />
                <Button Content="保存修改" Background="#A9E52E" Foreground="#0B100E"
                        BorderBrush="#A9E52E" Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
