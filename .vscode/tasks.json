{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: EndfieldPriceOverlay",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/EndfieldPriceOverlay/EndfieldPriceOverlay.csproj",
        "--configuration",
        "Debug",
        "--nologo"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run: EndfieldPriceOverlay",
      "type": "process",
      "command": "${workspaceFolder}/src/EndfieldPriceOverlay/bin/Debug/net10.0-windows/EndfieldPriceOverlay.exe",
      "dependsOn": "build: EndfieldPriceOverlay",
      "problemMatcher": []
    },
    {
      "label": "test: solution",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/EndfieldPriceOverlay.slnx",
        "--configuration",
        "Debug",
        "--nologo"
      ],
      "problemMatcher": "$msCompile",
      "group": "test"
    }
  ]
}
